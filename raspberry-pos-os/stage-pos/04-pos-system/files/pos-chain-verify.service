[Unit]
Description=Hop & Bites POS — dagelijkse SBA hash-chain verificatie (vervangt Vercel Cron)
After=pos-web.service
ConditionPathExists=/etc/pos-web/env

[Service]
Type=oneshot
EnvironmentFile=/etc/pos-web/env
# Needs Supabase, so this simply fails (and retries tomorrow) when the
# truck is offline — the chain itself is verified upstream.
ExecStart=/usr/bin/curl -fsS -m 120 -H "Authorization: Bearer ${CRON_SECRET}" http://127.0.0.1:3000/api/cron/verify-chain
