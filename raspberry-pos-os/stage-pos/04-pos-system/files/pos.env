# ============================================================
#  Hop & Bites POS — Pi configuratie
#
#  Dit bestand staat op de FAT-bootpartitie: na het flashen kun
#  je het vanaf Windows/macOS bewerken (verschijnt als "bootfs").
#  Na elke wijziging: SD-kaart terug in de Pi en (her)starten.
#  De Pi leest dit bestand bij ELKE boot opnieuw in.
#
#  Resultaat/foutmeldingen: zie STATUS.txt in deze map.
# ============================================================

# --- VERPLICHT: tenant + venue (UUID's uit Supabase) ---
ORG_ID=
VENUE_ID=

# --- VERPLICHT: Supabase (shared project) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Publieke (anon) key — nodig voor de web-app die lokaal op de Pi draait.
SUPABASE_ANON_KEY=

# --- myPOS PIN (leeg = PIN uitgeschakeld tot ingevuld) ---
MYPOS_SESSION_SECRET=
MYPOS_PARTNER_ID=
MYPOS_APP_ID=
MYPOS_BASE=https://eposapi.mypos.com

# --- Bonprinter (netwerkprinter in de truck) ---
PRINTER_NETWORK_ADDR=192.168.1.50
PRINTER_TYPE=star

# --- Netwerk ---
# Hostnaam: schermen openen https://<POS_HOSTNAME>.local (web-app) en de
# pi-bridge draait op https://<POS_HOSTNAME>.local:3001
POS_HOSTNAME=hopbites

# Optie A — EIGEN ACCESS POINT (aanbevolen voor de truck, geen internet
# nodig): de Pi zendt zelf een WiFi-netwerk uit waar de kassa/KDS/CFD-
# schermen mee verbinden. AP_PASS minimaal 8 tekens.
# Let op: wlan0 kan niet tegelijk AP zijn én met een ander WiFi verbinden;
# internet (voor Supabase-sync) gaat dan via de ethernet-poort.
AP_SSID=
AP_PASS=
# Geavanceerd: band bg=2.4GHz (default, beste bereik) of a=5GHz; kanaal.
AP_BAND=bg
AP_CHANNEL=6
AP_IP=10.42.0.1

# Optie B — verbind met een bestaand WiFi-netwerk (genegeerd als AP_SSID
# gezet is).
WIFI_SSID=
WIFI_PASS=
WIFI_COUNTRY=NL

# --- Kiosk (optioneel): URL die fullscreen op de HDMI-uitgang opent ---
# Bijv. het lokale CFD: https://hopbites.local/cfd  — leeg = geen kiosk.
KIOSK_URL=

# --- AI-functies in /admin (optioneel) ---
ANTHROPIC_API_KEY=

# --- Remote beheer (optioneel) ---
# 1 = Raspberry Pi Connect aan: remote shell via https://connect.raspberrypi.com,
# ook buiten je eigen netwerk. Eenmalig koppelen na de eerste boot:
#   ssh hopbites@hopbites.local  ->  rpi-connect signin
# LET OP: Pi Connect is een clouddienst — de signin én de verbinding werken
# alleen als de Pi zelf internet heeft. In AP-modus betekent dat: uplink via
# de ethernet-poort of USB-tethering (het AP blijft gewoon werken). Zit je
# op het AP-netwerk, dan heb je Pi Connect niet nodig: ssh hopbites@hopbites.local
ENABLE_RPI_CONNECT=0

# --- Geavanceerd (optioneel) ---
# Extra toegestane PWA-origins, komma-gescheiden. De lokale web-app
# (https://<POS_HOSTNAME>.local) is altijd al toegestaan.
ALLOWED_ORIGINS=
# Beperk mDNS tot één interface (bijv. wlan0) zodat er nooit op een
# tethered/WAN-interface geadverteerd wordt. Leeg = alle interfaces.
MDNS_INTERFACE=
SENTRY_DSN=
