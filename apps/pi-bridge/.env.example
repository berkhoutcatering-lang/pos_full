# Pi-bridge env — lives ONLY on the Pi. Never bundle to Vercel / PWA.
# After populating, copy to /etc/pi-bridge/env on the Pi.

PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# This Pi belongs to one venue
ORG_ID=00000000-0000-0000-0000-000000000001
VENUE_ID=00000000-0000-0000-0000-000000000010

# Supabase service role — backend-only writes (audit_log, outbox flush)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Tablet pairing JWT (HS256). 32+ chars. Generate: openssl rand -hex 32
PI_BRIDGE_PAIRING_SECRET=
PI_BRIDGE_ADMIN_TOKEN=

# myPOS ePOS — never leaves the Pi
MYPOS_BASE=https://eposapi.mypos.com
MYPOS_SESSION_SECRET=
MYPOS_PARTNER_ID=
MYPOS_APP_ID=

# Thermal printer (TCP on LAN)
PRINTER_NETWORK_ADDR=192.168.1.50
PRINTER_TYPE=star

# SQLite outbox + paired-tablets file path
SQLITE_PATH=/data/pi-bridge.sqlite

# TLS (mkcert in dev, self-signed or Let's Encrypt in prod)
TLS_CERT_PATH=/tls/cert.pem
TLS_KEY_PATH=/tls/key.pem

# Operational flags
DISABLE_MDNS=false
SIMULATE_SUPABASE_OUTAGE=false
