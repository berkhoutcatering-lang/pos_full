# --- Foundation ---
# Supabase (separate project from BBQ Architect; shared auth via SSO later)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Default theme preset if org has no override
NEXT_PUBLIC_DEFAULT_THEME_PRESET=hopbites

# App's public URL — used for sharing + redirects
NEXT_PUBLIC_APP_URL=https://hopbites.app

# --- Admin ---
# Anthropic — admin chat (Haiku 4.5) + monthly summary (Sonnet 4.6)
ANTHROPIC_API_KEY=

# Pi-bridge admin reach-through for /admin/devices issue-pair-code
PI_BRIDGE_URL=https://hopbites.local:3001
PI_BRIDGE_ADMIN_TOKEN=

# Next.js Server-Action closure encryption key.
# REQUIRED for multi-instance Vercel deploys; closures crash with
# "decryption failed" if instances see different keys.
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Cron secret for /api/cron/verify-chain (Vercel Cron Authorization)
CRON_SECRET=

# --- Observability ---
# Sentry (errors + tracing). Leave blank to keep the SDK a no-op.
# NEXT_PUBLIC_ is exposed to the browser; SENTRY_DSN covers server/edge.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source-map upload at build time (CI/prod only — optional).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog product analytics (optional — provider is gated on this key;
# wiring the client is a follow-up, see build orchestrator notes).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
